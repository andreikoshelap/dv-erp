APP_NAME=gatto
APP_ENV=production
APP_KEY=                      # php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.gatto-piccolo.com

FRONTEND_URL=https://gatto-piccolo.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gatto
DB_USERNAME=gatto
DB_PASSWORD=change-me

# Demo runs on seeded data (no live SmartAccounts keys)
ERP_FAKE=true

# Required for the ask endpoint
ANTHROPIC_API_KEY=sk-ant-...

# AI SDK defaults to openai; make Anthropic the default provider
# (the agent also pins it via attribute, but this is tidy)
CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
